MONGO_URI=mongodb+srv://<username>:<password>@<cluster-url>/?retryWrites=true&w=majority
MONGO_DB_NAME=aromaz_pos
CORS_ORIGINS=http://localhost:5173
ENVIRONMENT=development
OWNER_EMAILS=owner@example.com
OTP_TTL_MINUTES=10
OTP_MAX_ATTEMPTS=5
OTP_COOLDOWN_SECONDS=30
OTP_LOCKOUT_MINUTES=15
TOTP_ISSUER="Aromaz POS"
TOTP_ACCOUNT_NAME=owner@aromaz.local
TOTP_SETUP_KEY=
SESSION_TTL_HOURS=720
SESSION_COOKIE_NAME=pos_session
SESSION_SECRET=replace-with-strong-random-secret
EBILL_TOKEN_TTL_HOURS=24
EBILL_LINK_SECRET=
EBILL_PUBLIC_BASE_URL=
MSG91_AUTH_KEY=
MSG91_SENDER_ID=
MSG91_ROUTE=4
MSG91_COUNTRY_CODE=91
MSG91_RETRY_ATTEMPTS=2
MSG91_RETRY_DELAY_MS=250
RESEND_API_KEY=
RESEND_FROM_EMAIL=billing@aromaz.co.in
RESEND_RETRY_ATTEMPTS=2
RESEND_RETRY_DELAY_MS=250
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite
GEMINI_TIMEOUT_SECONDS=75
GEMINI_RETRY_ATTEMPTS=1
GEMINI_RETRY_BACKOFF_MS=600
GEMINI_FALLBACK_MODELS=gemini-2.5-flash,gemini-3-flash
GEMINI_INPUT_COST_PER_MILLION_USD=0.30
GEMINI_OUTPUT_COST_PER_MILLION_USD=2.50
GEMINI_BILL_THOUGHTS_TOKENS=true
TAX_RATE_PERCENT=5.0
